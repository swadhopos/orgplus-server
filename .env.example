# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/orgplus

# Firebase Configuration
# Option 1: Use service account file path (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=../orgplus-b4585-firebase-adminsdk-fbsvc-ad9d478edd.json

# Option 2: Use individual environment variables (for containerized deployments)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=info

# Bootstrap Configuration
BOOTSTRAP_PASSWORD=ChangeThisPassword123!

# Storage Configuration (Cloudflare R2 / S3 Compatible)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your-account-id-or-token
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=orgplus-storage
R2_PUBLIC_URL=https://your-public-url.r2.dev

# Backup Configuration
BACKUP_ENV=dev
BACKUP_INTERVAL_HOURS=7
BACKUP_RETENTION_DAYS=2
